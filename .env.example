# GitHub Token for PR-Test-Agent
GITHUB_TOKEN=your_github_token_here

# Test repo where generated tests will be pushed
TEST_REPO_OWNER=your_username
TEST_REPO_NAME=your_test_repo

# Playwright Test Credentials
PLAYWRIGHT_USER_ID=your_playwright_user_id
PLAYWRIGHT_SESSION_ID=your_playwright_session_id
PLAYWRIGHT_TEST_BASE_URL=https://demo.pristinedata.ai

# Anthropic API Key for Agentic Testing
ANTHROPIC_API_KEY=your_anthropic_api_key
